# MongoDB (local: mongodb://127.0.0.1:27017/the-negotiator)
MONGODB_URI=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Agent IDs — created via `npm run create-agents` (or manually in the dashboard)
ELEVENLABS_INTAKE_AGENT_ID=
ELEVENLABS_BUYER_AGENT_ID=
# Vendor counter-agent for agent-vs-agent calls (two live ElevenLabs sessions)
ELEVENLABS_VENDOR_AGENT_ID=

# Anthropic — vendor brains, doc intake, report narrative
ANTHROPIC_API_KEY=

# Optional: live vendor discovery (canned response used when unset)
# Places API (New): vendor discovery plus moving-location suggestions
GOOGLE_PLACES_API_KEY=

# Twilio WhatsApp (Console → Messaging → Try it out → WhatsApp sandbox)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Public URL of this app (ngrok in dev) — used for Twilio signature validation + links
PUBLIC_BASE_URL=

# OpenAI — engine LLM (default provider) + WhatsApp intake chat
OPENAI_API_KEY=
# Engine LLM provider: openai (default when OPENAI_API_KEY is set) | anthropic
LLM_PROVIDER=

# Telegram bot (BotFather token + any random webhook secret)
TELEGRAM_BOT_TOKEN=
# Used as Telegram's setWebhook secret_token. Query-string validation remains
# supported for existing development webhooks.
TELEGRAM_WEBHOOK_SECRET=

# Real phone calls (both required; then re-run `npm run create-agents` so the
# buyer agent's tools switch to webhooks against PUBLIC_URL)
# Attach/import a phone number in the ElevenLabs dashboard -> Phone numbers
ELEVENLABS_PHONE_NUMBER_ID=
# Publicly reachable base URL of this app (deployment or tunnel), no trailing slash
PUBLIC_URL=

# Wasabi storage for recordings + uploaded documents (falls back to local
# public/recordings when unset)
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_BUCKET_NAME=
WASABI_REGION=
WASABI_CDN_URL=

# Public chat-bot links (client-side; NEXT_PUBLIC_ vars are inlined at build)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_WHATSAPP_NUMBER=14155238886
NEXT_PUBLIC_WHATSAPP_JOIN_CODE=
