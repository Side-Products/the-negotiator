# MongoDB (local: mongodb://127.0.0.1:27017/the-negotiator)
MONGODB_URI=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Agent IDs — created via `npm run create-agents` (or manually in the dashboard)
ELEVENLABS_INTAKE_AGENT_ID=
ELEVENLABS_BUYER_AGENT_ID=

# Anthropic — vendor brains, doc intake, report narrative
ANTHROPIC_API_KEY=

# Optional: live vendor discovery (canned response used when unset)
GOOGLE_PLACES_API_KEY=
